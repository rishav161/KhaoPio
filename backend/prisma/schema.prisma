datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum RoleName {
  SUPER_ADMIN
  STORE_MANAGER
  CASHIER
  WAITER
  KITCHEN_CHEF
}

enum OrderStatus {
  DRAFT
  KITCHEN_PENDING
  PREPARING
  READY
  BILL_REQUESTED
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

enum PaymentMethod {
  CASH
  CARD
  UPI
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  SEATED
  CANCELLED
}


model User {
  id           String       @id @default(uuid())
  name         String
  email        String?      @unique
  passwordHash String?      // For email/password logins (Super Admin, Store Manager)
  pin          String?      // Hashed 4-digit PIN for tablet quick-login (Waiters, Cashiers, Chefs)
  status       UserStatus   @default(INVITED)
  roleId       String
  role         Role         @relation(fields: [roleId], references: [id])
  
  restaurantId String?
  restaurant   Restaurant?  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  
  // Orders taken by this user (typically as waiter)
  waiterOrders Order[]      @relation("WaiterOrders")
  
  // Payments processed by this user (typically as cashier)
  payments     Payment[]
  
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Role {
  id          String           @id @default(uuid())
  name        RoleName         @unique
  permissions RolePermission[]
  users       User[]
  invitations Invitation[]
}

model Permission {
  id           String           @id @default(uuid())
  name         String           @unique // e.g. "create:kot", "pay:order", "view:reports", "manage:staff"
  description  String?
  roles        RolePermission[]
  sidebarItems SidebarItem[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model SidebarItem {
  id           String        @id @default(uuid())
  label        String        // Display name in sidebar (e.g. "Dashboard", "Orders")
  icon         String?       // Lucide icon identifier (e.g. "LayoutDashboard")
  path         String        // Frontend client route (e.g. "/dashboard")
  order        Int           @default(0) // Order for rendering
  permissionId String?       // Optional: Permission required to view this item
  permission   Permission?   @relation(fields: [permissionId], references: [id], onDelete: SetNull)
  
  // Support nested sub-menu items
  parentId     String?
  parent       SidebarItem?  @relation("SubItems", fields: [parentId], references: [id], onDelete: Cascade)
  subItems     SidebarItem[] @relation("SubItems")
}

model Invitation {
  id           String      @id @default(uuid())
  email        String      @unique
  roleId       String
  role         Role        @relation(fields: [roleId], references: [id])
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  token        String      @unique
  isUsed       Boolean     @default(false)
  expiresAt    DateTime
  createdAt    DateTime    @default(now())
}

model Order {
  id                  String      @id @default(uuid())
  orderNumber         Int         @default(autoincrement())
  status              OrderStatus @default(KITCHEN_PENDING)
  subtotal            Float
  
  // Snapshots of applied rates/charges
  taxRate             Float       @default(5.0)
  taxTotal            Float       @default(0.0)
  serviceChargeRate   Float       @default(5.0)
  serviceChargeTotal  Float       @default(0.0)
  
  // Discount details
  discountTotal       Float       @default(0.0)
  couponId            String?
  coupon              Coupon?     @relation(fields: [couponId], references: [id], onDelete: SetNull)
  couponCode          String?     // Text snapshot of coupon code
  
  grandTotal          Float
  
  payments            Payment[]
  
  restaurantId        String?
  restaurant          Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  
  waiterId            String
  waiter              User        @relation("WaiterOrders", fields: [waiterId], references: [id])
  
  tableId             String?
  table               DiningTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)

  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  items               OrderItem[]
}

model OrderItem {
  id         String @id @default(uuid())
  menuItemId String
  name       String
  quantity   Int
  price      Float
  orderId    String
  order      Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Restaurant {
  id                   String         @id @default(uuid())
  name                 String
  users                User[]
  invitations          Invitation[]
  categories           MenuCategory[]
  menuItems            MenuItem[]
  orders               Order[]
  coupons              Coupon[]
  tables               DiningTable[]
  bookings             Booking[]
  defaultTaxRate       Float          @default(5.0)
  defaultServiceCharge Float          @default(5.0)
  address              String?
  phone                String?
  gstin                String?
  logo                 String?
  thankYouMessage      String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
}

model Coupon {
  id             String       @id @default(uuid())
  code           String
  description    String?
  discountType   DiscountType @default(PERCENTAGE)
  discountValue  Float
  minSubtotal    Float        @default(0.0)
  maxDiscount    Float?
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean      @default(true)
  
  restaurantId   String
  restaurant     Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  
  orders         Order[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([code, restaurantId])
}

model Payment {
  id                   String        @id @default(uuid())
  amount               Float
  paymentMethod        PaymentMethod
  transactionReference String?
  
  orderId              String
  order                Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  cashierId            String
  cashier              User          @relation(fields: [cashierId], references: [id])
  
  createdAt            DateTime      @default(now())
}

model MenuCategory {
  id           String     @id @default(uuid())
  name         String
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItems    MenuItem[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([name, restaurantId])
}

model MenuItem {
  id           String       @id @default(uuid())
  name         String
  description  String?
  price        Float
  image        String?      // E.g. emoji or image path
  code         String       // Short code
  isAvailable  Boolean      @default(true)
  categoryId   String
  category     MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  
  @@unique([code, restaurantId])
}

model OtpVerification {
  id         String   @id @default(uuid())
  email      String   @unique
  otp        String
  isVerified Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model DiningTable {
  id           String      @id @default(uuid())
  name         String
  capacity     Int
  status       TableStatus @default(AVAILABLE)
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orders       Order[]
  bookings     Booking[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([name, restaurantId])
}

model Booking {
  id           String        @id @default(uuid())
  customerName String
  customerPhone String?
  bookingTime  DateTime
  guestsCount  Int
  status       BookingStatus @default(CONFIRMED)
  tableId      String
  table        DiningTable   @relation(fields: [tableId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}


